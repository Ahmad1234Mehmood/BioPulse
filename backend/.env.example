# Database Configuration (Future)
DATABASE_URL=sqlite:///./facial_biometrics.db

# Face Recognition Configuration
FACE_DETECTION_THRESHOLD=0.5
FACE_SIMILARITY_THRESHOLD=0.7

# Deployment (Render)
RENDER_EXTERNAL_URL=https://facial-biometrics-backend.render.com
